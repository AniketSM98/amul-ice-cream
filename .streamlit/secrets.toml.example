# Copy the content below into Streamlit Cloud → App Settings → Secrets
# Replace values with your actual TiDB Cloud credentials

DB_HOST     = "gateway01.us-east-1.prod.aws.tidbcloud.com"
DB_PORT     = 4000
DB_USER     = "your_tidb_username.your_cluster_id"
DB_PASSWORD = "your_tidb_password"
DB_NAME     = "ice_cream_shop"
